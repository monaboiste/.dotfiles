{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "ai",
      },
    },
    "localllm": {
      "name": "Local LLM",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "qwen3.5-35b-a3b-mlx-5": {
          "name": "Qwen3.5 A3B 35B",
        },
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
      },
    },
  },
  "mcp": {
    "mcp-steroid": {
      "type": "remote",
      "url": "http://127.0.0.1:6315/mcp",
      "enabled": false,
    },
  },
  "watcher": {
    "ignore": [".git/**", "node_modules/**", "dist/**", "build/**"],
  },
}
