{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "ai"
      }
    },
    "localllm": {
      "name": "Local LLM",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "qwen3.5-35b-a3b-mlx-5:2": {
          "name": "Qwen3.5 A3B 35B",
          "context": 10000,
          "output": 5000
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**"
    ]
  }
}
