{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "ai"
      }
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**"
    ]
  }
}
